{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "$app": ["./.svelte-kit/types"],
      "$app/environment": ["./.svelte-kit/types"],
      "$app/forms": ["./.svelte-kit/types"],
      "$app/navigation": ["./.svelte-kit/types"],
      "$app/stores": ["./.svelte-kit/types"],
      "$app/*": ["./.svelte-kit/types"]
    }
  }
}
