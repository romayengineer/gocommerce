{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "$app/*": [".svelte-kit/runtime/*"],
      "$lib/*": ["src/lib/*"]
    }
  },
  "include": ["src", ".svelte-kit/generated"],
  "exclude": ["node_modules"]
}
